    .downloadbutton { background: transparent; color: #f3f0ff; padding: 15px 30px; border: 1px solid #6c757d; border-radius: 5px; font-weight: bold; cursor: pointer; font-size: 16px; }
    .linkedinbutton { background: #0a66c2; color: white; padding: 15px 30px; border: none; border-radius: 50px; font-weight: bold; cursor: pointer; font-size: 16px; }
